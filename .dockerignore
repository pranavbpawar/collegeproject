# ==============================================================================
# TBAPS — Docker Ignore
# Excludes files that should NOT be sent to Docker build context.
# This dramatically speeds up builds and prevents secrets from leaking.
# ==============================================================================

# Git
.git
.gitignore
.github

# Python virtual environments
.venv
venv
backend/.venv
backend/venv
__pycache__
*.pyc
*.pyo
*.pyd
.pytest_cache
backend/.pytest_cache
*.egg-info
dist/
*.dist-info/

# Node
node_modules
frontend/node_modules
frontend/dist

# Test artifacts
backend/tests/__pycache__
*.log

# IDE / Editor
.vscode
.idea
*.swp
*.swo
.DS_Store

# Environment (never include secrets in build context)
.env.test
.env.local
backend/.env.test

# Documentation (not needed in image)
docs/
*.md
LOCAL_SETUP_GUIDE.md
SETUP_STEP_BY_STEP.md
DEPLOYMENT_CHECKLIST.md
NATIVE_DEPLOYMENT_GUIDE.md
selfhosted_guide.md
PROJECT_STATUS_REPORT.md

# Large binary files
*.deb
cloudflared.deb
agent/
execmonitor/

# VPN / scripts (not part of the container)
vpn/
scripts/
systemd/
diagnose-openvpn.sh
fix-openvpn.sh
setup-openvpn-simple.sh

# Supabase migration SQL (DB schema is managed by alembic inside the container)
supabase_full_migration.sql

# Simulation scripts
simulate_agent.py
test_delete.py
