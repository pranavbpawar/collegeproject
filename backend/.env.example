# ==============================================================================
# TBAPS Backend — Environment Configuration Template
# Copy to backend/.env and fill in values.
# NEVER commit .env to version control.
# ==============================================================================

APP_NAME=TBAPS
APP_ENV=development
DEBUG=False
SECRET_KEY=CHANGE_ME_generate_with__python3_-c__import_secrets_print_secrets.token_urlsafe_32__

# Database
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/zerotrust
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=zerotrust
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (optional)
REDIS_URL=redis://localhost:6379/0
REDIS_OPTIONAL=true

# JWT
JWT_SECRET_KEY=CHANGE_ME_generate_with__python3_-c__import_secrets_print_secrets.token_urlsafe_64__
JWT_ALGORITHM=HS256
JWT_ISSUER=tbaps
JWT_AUDIENCE=tbaps-api
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption (32 hex chars)
ENCRYPTION_KEY=CHANGE_ME_32_hex_characters

# CORS & URLs
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:8000

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Email
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=CHANGE_ME@yourdomain.com
EMAIL_FROM_NAME=TBAPS Admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME@gmail.com
SMTP_PASSWORD=CHANGE_ME_gmail_app_password
SMTP_USE_TLS=true
SENDGRID_API_KEY=
AGENT_SEND_RATE_LIMIT=10/hour

# OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Monitoring (optional)
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
