# ==============================================================================
# TBAPS — Environment Configuration Template
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION
# APP_ENV: development | production | testing
# ------------------------------------------------------------------------------
APP_NAME=TBAPS
APP_ENV=development
DEBUG=False
SECRET_KEY=CHANGE_ME_generate_with__python3_-c__import_secrets_print_secrets.token_urlsafe_32__

# ------------------------------------------------------------------------------
# DATABASE
# Local dev  → postgresql://user:pass@localhost:5432/dbname
# Production → get pooled connection string from your DB provider (sslmode=require)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/zerotrust
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=zerotrust
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ------------------------------------------------------------------------------
# REDIS  (optional — app runs without it when REDIS_OPTIONAL=true)
# Local dev  → redis://localhost:6379/0
# Production → get from Render / Upstash dashboard
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_OPTIONAL=true

# ------------------------------------------------------------------------------
# RABBITMQ  (optional — leave as guest/guest for local dev)
# ------------------------------------------------------------------------------
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# ------------------------------------------------------------------------------
# JWT
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
# ------------------------------------------------------------------------------
JWT_SECRET_KEY=CHANGE_ME_generate_with__python3_-c__import_secrets_print_secrets.token_urlsafe_64__
JWT_ALGORITHM=HS256
JWT_ISSUER=tbaps
JWT_AUDIENCE=tbaps-api
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# ENCRYPTION KEY  (must be exactly 32 hex chars)
# Generate: python3 -c "import secrets; print(secrets.token_hex(16))"
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=CHANGE_ME_32_hex_characters

# ------------------------------------------------------------------------------
# CORS & URLS
# CORS_ORIGINS : JSON array of allowed frontend origins (no trailing /)
# FRONTEND_URL : Your deployed frontend URL
# SERVER_URL   : Your deployed backend URL
# ------------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
SERVER_URL=http://localhost:8000

# ------------------------------------------------------------------------------
# LOGGING
# LOG_LEVEL  : DEBUG | INFO | WARNING | ERROR | CRITICAL
# LOG_FORMAT : text | json
# ------------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text

# ------------------------------------------------------------------------------
# CELERY  (optional)
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=amqp://guest:guest@localhost:5672/
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------------------------------------------------------------------------------
# VPN / TRAFFIC MONITORING
# ------------------------------------------------------------------------------
CAPTURE_INTERFACE=eth0
CAPTURE_FILTER=udp port 53 or tcp port 443

# ------------------------------------------------------------------------------
# EMAIL — SMTP Configuration
# ------------------------------------------------------------------------------
EMAIL_PROVIDER=smtp
EMAIL_FROM_ADDRESS=CHANGE_ME@yourdomain.com
EMAIL_FROM_NAME=TBAPS Admin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=CHANGE_ME@gmail.com
SMTP_PASSWORD=CHANGE_ME_gmail_app_password
SMTP_USE_TLS=true

# SendGrid (alternative to SMTP — leave blank to disable)
SENDGRID_API_KEY=

# Rate limit for the send-agent endpoint
AGENT_SEND_RATE_LIMIT=10/hour

# ------------------------------------------------------------------------------
# GOOGLE OAUTH  (optional — leave blank to disable)
# ------------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ------------------------------------------------------------------------------
# MICROSOFT OAUTH  (optional — leave blank to disable)
# ------------------------------------------------------------------------------
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ------------------------------------------------------------------------------
# MONITORING  (optional)
# ------------------------------------------------------------------------------
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
